# EmailJS — website inquiry popup
# https://dashboard.emailjs.com/
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_SERVICE_ID=service_k872vdi

# Customer auto-reply (sent TO the email they type in the form)
# In EmailJS → template → To Email: {{email}} (from address = connected service in dashboard)
# Template body variables: {{name}} {{email}} {{phone}} {{message}}
VITE_EMAILJS_TEMPLATE_ID=template_irt46gq

# Optional: second template so YOU get a copy at official@juliarense.com
# To Email = {{to_email}}, body uses {{name}} {{email}} {{phone}} {{message}}
# VITE_EMAILJS_NOTIFY_TEMPLATE_ID=template_xxxxx
# VITE_INQUIRY_TO_EMAIL=official@juliarense.com
